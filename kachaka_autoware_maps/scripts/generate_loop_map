#!/usr/bin/env python3
# Copyright 2026 Yutaka Kondo
# Licensed under the Apache License, Version 2.0 (the "License").

"""Snapshot /kachaka/mapping/map and write a circular loop lanelet2 map.

Captures one OccupancyGrid (latched / transient_local), finds the largest free
rectangle, fits a circular one-way loop inside it, and writes the map directory:
  lanelet2_map.osm, map_projector_info.yaml, loop_params.yaml

Run with the Kachaka bridge up and the robot OFF the dock (the body LiDAR only
spins off-dock, so /kachaka/mapping/map is current). The geometry parameters
default to the M3 bring-up values and are tuned on the robot.
"""

import sys
from pathlib import Path
from threading import Event

import rclpy
from nav_msgs.msg import OccupancyGrid
from rclpy.duration import Duration
from rclpy.node import Node
from rclpy.qos import QoSDurabilityPolicy, QoSHistoryPolicy, QoSProfile, QoSReliabilityPolicy

from kachaka_autoware_maps.loop_map_gen import (
    MAP_PROJECTOR_INFO_YAML,
    loop_params_yaml,
    occupancy_to_loop_osm,
)

DEFAULT_INPUT_TOPIC = "/kachaka/mapping/map"
DEFAULT_OUTPUT_DIR = str(Path.home() / "maps" / "kachaka_loop")
DEFAULT_MAP_TIMEOUT_SEC = 30.0


class GenerateLoopMapNode(Node):
    def __init__(self) -> None:
        super().__init__("generate_loop_map")
        self.declare_parameter("input_topic", DEFAULT_INPUT_TOPIC)
        self.declare_parameter("output_dir", DEFAULT_OUTPUT_DIR)
        self.declare_parameter("lane_width", 0.6)
        self.declare_parameter("margin", 0.05)
        self.declare_parameter("max_radius", 0.9)
        self.declare_parameter("speed_limit", 0.3)
        self.declare_parameter("num_segments", 16)
        self.declare_parameter("occupied_threshold", 50)
        self.declare_parameter("treat_unknown_as_occupied", True)
        self.declare_parameter("map_timeout", DEFAULT_MAP_TIMEOUT_SEC)

        self.input_topic = str(self.get_parameter("input_topic").value)
        self.output_dir = Path(str(self.get_parameter("output_dir").value)).expanduser()
        self.lane_width = float(self.get_parameter("lane_width").value)
        self.margin = float(self.get_parameter("margin").value)
        self.max_radius = float(self.get_parameter("max_radius").value)
        self.speed_limit = float(self.get_parameter("speed_limit").value)
        self.num_segments = int(self.get_parameter("num_segments").value)
        self.occupied_threshold = int(self.get_parameter("occupied_threshold").value)
        self.treat_unknown_as_occupied = bool(
            self.get_parameter("treat_unknown_as_occupied").value
        )
        self.map_timeout_sec = float(self.get_parameter("map_timeout").value)

        self.done = Event()
        self.exit_code = 0
        # /kachaka/mapping/map is latched (transient_local); match it or the
        # one already-published grid is never delivered.
        map_qos = QoSProfile(
            reliability=QoSReliabilityPolicy.RELIABLE,
            durability=QoSDurabilityPolicy.TRANSIENT_LOCAL,
            history=QoSHistoryPolicy.KEEP_LAST,
            depth=1,
        )
        self.sub = self.create_subscription(
            OccupancyGrid, self.input_topic, self._on_map, map_qos
        )
        self.get_logger().info(
            f"Waiting on {self.input_topic}; will write to {self.output_dir}"
        )

    def _on_map(self, msg: OccupancyGrid) -> None:
        if self.done.is_set():
            return
        try:
            self._process(msg)
        except Exception as exc:  # noqa: BLE001 - report any failure and exit
            self.get_logger().error(f"Loop-map generation failed: {exc}")
            self.exit_code = 2
        finally:
            self.done.set()

    def _process(self, msg: OccupancyGrid) -> None:
        info = msg.info
        q = info.origin.orientation
        if abs(q.z) > 1e-3 or abs(q.w - 1.0) > 1e-3:
            self.get_logger().warn(
                "OccupancyGrid origin is rotated; loop placement assumes an "
                "axis-aligned grid and ignores the rotation."
            )
        osm, params = occupancy_to_loop_osm(
            list(msg.data),
            width=info.width,
            height=info.height,
            resolution=info.resolution,
            origin_x=info.origin.position.x,
            origin_y=info.origin.position.y,
            lane_width=self.lane_width,
            margin=self.margin,
            max_radius=self.max_radius,
            speed_limit=self.speed_limit,
            num_segments=self.num_segments,
            occupied_threshold=self.occupied_threshold,
            treat_unknown_as_occupied=self.treat_unknown_as_occupied,
        )
        self.output_dir.mkdir(parents=True, exist_ok=True)
        (self.output_dir / "lanelet2_map.osm").write_text(osm)
        (self.output_dir / "map_projector_info.yaml").write_text(MAP_PROJECTOR_INFO_YAML)
        (self.output_dir / "loop_params.yaml").write_text(
            loop_params_yaml(params, self.lane_width, self.speed_limit, self.num_segments)
        )
        self.get_logger().info(
            f"Wrote loop map to {self.output_dir}: centre=({params.center_x:.3f}, "
            f"{params.center_y:.3f}) m, radius={params.radius:.3f} m, "
            f"{self.num_segments} segments"
        )


def main() -> int:
    rclpy.init()
    node = GenerateLoopMapNode()
    try:
        deadline = node.get_clock().now() + Duration(seconds=node.map_timeout_sec)
        while rclpy.ok() and not node.done.is_set():
            if node.get_clock().now() > deadline:
                node.get_logger().error(
                    f"No {node.input_topic} within {node.map_timeout_sec}s; is the "
                    "bridge up and the robot off the dock?"
                )
                return 3
            rclpy.spin_once(node, timeout_sec=0.1)
        return node.exit_code
    finally:
        node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()


if __name__ == "__main__":
    sys.exit(main())
