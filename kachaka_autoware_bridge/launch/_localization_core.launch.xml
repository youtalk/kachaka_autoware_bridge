<?xml version="1.0"?>
<launch>
  <!--
    Vendored from autoware_core_localization/launch/autoware_core_localization.launch.xml
    (prebuilt autoware_core overlay at ~/ros/jazzy; vendored 2026-06-12).
    Local changes - re-sync the node list / params with upstream on bumps:
      * every absolute /localization prefix is $(var ns) so a SHADOW instance
        (ns:=/localization/shadow) can run beside the Kachaka TF passthrough
        without topic collisions, and the NDT mode instance uses the real names;
      * the EKF node is inlined (upstream wraps ekf_localizer.launch.xml, and
        an <include> cannot inject a remap) so its hardcoded map->base_link
        TF broadcast can be remapped to $(var ekf_tf_topic). It must NEVER
        reach /tf: in shadow mode it would corrupt the Kachaka tree (base_link
        would gain a second parent), and in ndt mode the map_to_odom_adapter
        owns the map->odom edge instead;
      * pose_initializer's fixed interface names /localization/initialize and
        /localization/initialization_state are remapped under $(var ns)
        (identity when ns:=/localization). The internal initialpose3d topic
        (pose_initializer pose_reset -> EKF initialpose) is moved to
        $(var ns)/initialpose3d so a shadow instance stays isolated; both ends
        target the same name, and recovery seeds via the $(var ns)/initialize
        service, so no external /initialpose3d publisher is required.
    Upstream oddity reproduced faithfully: the EKF publishes
    $(var ns)/kinematic_state directly while stop_filter reads the
    never-published $(var ns)/pose_twist_fusion_filter/kinematic_state, so
    stop_filter is dormant. Do not "fix" here; behavior must match upstream.
  -->
  <arg name="ns" default="/localization"
       description="Absolute namespace for the stack (/localization or /localization/shadow)."/>
  <arg name="ekf_tf_topic" default="/localization/tf_unused"
       description="Where the EKF's unconditional map->base_link TF broadcast goes. Never /tf."/>
  <arg name="lidar_input_topic" default="/sensing/lidar/top/pointcloud_raw_ex"/>
  <arg name="vehicle_twist_input_topic" default="/sensing/vehicle_velocity_converter/twist_with_covariance"/>
  <arg name="gnss_input_topic" default="/sensing/gnss/pose_with_covariance"/>
  <arg name="pose_initializer_param_path"
       default="$(find-pkg-share kachaka_autoware_bridge)/config/pose_initializer.param.yaml"/>
  <!-- autoware_core_localization ships an older ekf_localizer.param.yaml missing
       diagnostics.diagnostics_publish_frequency; use the package's own complete
       one (same workaround as launch/localization.launch.xml). -->
  <arg name="ekf_localizer_param_path"
       default="$(find-pkg-share autoware_ekf_localizer)/config/ekf_localizer.param.yaml"/>
  <arg name="stop_filter_param_path"
       default="$(find-pkg-share autoware_core_localization)/config/stop_filter.param.yaml"/>
  <arg name="twist2accel_param_path"
       default="$(find-pkg-share autoware_core_localization)/config/twist2accel.param.yaml"/>
  <arg name="voxel_grid_downsample_filter_param_file"
       default="$(find-pkg-share autoware_core_localization)/config/voxel_grid_downsample_filter.param.yaml"/>
  <arg name="ndt_scan_matcher_param_path"
       default="$(find-pkg-share autoware_core_localization)/config/ndt_scan_matcher.param.yaml"/>

  <group>
    <push-ros-namespace namespace="$(var ns)"/>

    <group>
      <push-ros-namespace namespace="pose_estimator"/>
      <node pkg="autoware_downsample_filters" exec="voxel_grid_downsample_filter_node"
            name="voxel_grid_downsample_filter_node">
        <param from="$(var voxel_grid_downsample_filter_param_file)"/>
        <remap from="input" to="$(var lidar_input_topic)"/>
        <remap from="output" to="$(var ns)/util/downsample/pointcloud"/>
      </node>

      <include file="$(find-pkg-share autoware_ndt_scan_matcher)/launch/ndt_scan_matcher.launch.xml">
        <arg name="input_pointcloud" value="$(var ns)/util/downsample/pointcloud"/>
        <arg name="input_initial_pose_topic" value="$(var ns)/pose_twist_fusion_filter/biased_pose_with_covariance"/>
        <arg name="input_regularization_pose_topic" value="$(var gnss_input_topic)"/>
        <arg name="input_service_trigger_node" value="$(var ns)/pose_estimator/trigger_node"/>
        <arg name="output_pose_topic" value="$(var ns)/pose_estimator/pose"/>
        <arg name="output_pose_with_covariance_topic" value="$(var ns)/pose_estimator/pose_with_covariance"/>
        <arg name="client_map_loader" value="/map/get_differential_pointcloud_map"/>
        <arg name="param_file" value="$(var ndt_scan_matcher_param_path)"/>
      </include>
    </group>

    <group>
      <push-ros-namespace namespace="twist_estimator"/>
      <node pkg="topic_tools" exec="relay" name="twist_estimator_relay" output="log">
        <param name="input_topic" value="$(var vehicle_twist_input_topic)"/>
        <param name="output_topic" value="$(var ns)/twist_estimator/twist_with_covariance"/>
        <param name="type" value="geometry_msgs/msg/TwistWithCovarianceStamped"/>
        <param name="reliability" value="reliable"/>
      </node>
    </group>

    <group>
      <push-ros-namespace namespace="pose_twist_fusion_filter"/>
      <!-- EKF inlined from autoware_ekf_localizer/launch/ekf_localizer.launch.xml
           solely to add the /tf remap; topic wiring matches the upstream
           core-localization include exactly (with /localization -> $(var ns)). -->
      <node pkg="autoware_ekf_localizer" exec="autoware_ekf_localizer_node" output="both">
        <remap from="/tf" to="$(var ekf_tf_topic)"/>
        <remap from="in_pose_with_covariance" to="$(var ns)/pose_estimator/pose_with_covariance"/>
        <remap from="in_twist_with_covariance" to="$(var ns)/twist_estimator/twist_with_covariance"/>
        <remap from="initialpose" to="$(var ns)/initialpose3d"/>
        <remap from="trigger_node_srv" to="trigger_node"/>
        <remap from="ekf_odom" to="$(var ns)/kinematic_state"/>
        <remap from="ekf_pose" to="pose"/>
        <remap from="ekf_pose_with_covariance" to="$(var ns)/pose_with_covariance"/>
        <remap from="ekf_biased_pose" to="biased_pose"/>
        <remap from="ekf_biased_pose_with_covariance" to="biased_pose_with_covariance"/>
        <remap from="ekf_twist" to="twist"/>
        <remap from="ekf_twist_with_covariance" to="twist_with_covariance"/>
        <remap from="debug/processing_time_ms" to="debug/processing_time_ms"/>
        <param from="$(var ekf_localizer_param_path)"/>
      </node>

      <include file="$(find-pkg-share autoware_stop_filter)/launch/stop_filter.launch.xml">
        <arg name="use_twist_with_covariance" value="True"/>
        <arg name="input_odom_name" value="$(var ns)/pose_twist_fusion_filter/kinematic_state"/>
        <arg name="input_twist_with_covariance_name" value="$(var ns)/pose_twist_fusion_filter/twist_with_covariance"/>
        <arg name="output_odom_name" value="$(var ns)/kinematic_state"/>
        <arg name="param_path" value="$(var stop_filter_param_path)"/>
      </include>

      <include file="$(find-pkg-share autoware_twist2accel)/launch/twist2accel.launch.xml">
        <arg name="in_odom" value="$(var ns)/kinematic_state"/>
        <arg name="in_twist" value="$(var ns)/twist_estimator/twist_with_covariance"/>
        <arg name="out_accel" value="$(var ns)/acceleration"/>
        <arg name="param_file" value="$(var twist2accel_param_path)"/>
      </include>
    </group>

    <group>
      <push-ros-namespace namespace="util"/>
      <node pkg="autoware_pose_initializer" exec="autoware_pose_initializer_node" output="both">
        <param from="$(var pose_initializer_param_path)"/>
        <remap from="/localization/initialize" to="$(var ns)/initialize"/>
        <remap from="/localization/initialization_state" to="$(var ns)/initialization_state"/>
        <remap from="ndt_align" to="$(var ns)/pose_estimator/ndt_align_srv"/>
        <remap from="stop_check_twist" to="$(var vehicle_twist_input_topic)"/>
        <remap from="gnss_pose_cov" to="$(var gnss_input_topic)"/>
        <remap from="pose_reset" to="$(var ns)/initialpose3d"/>
        <remap from="ekf_trigger_node" to="$(var ns)/pose_twist_fusion_filter/trigger_node"/>
        <remap from="ndt_trigger_node" to="$(var ns)/pose_estimator/trigger_node"/>
        <param name="map_height_fitter.map_loader_name" value="/map/pointcloud_map_loader"/>
        <param name="map_height_fitter.target" value="pointcloud_map"/>
        <remap from="~/pointcloud_map" to="/map/pointcloud_map"/>
        <remap from="~/partial_map_load" to="/map/get_partial_pointcloud_map"/>
        <remap from="~/vector_map" to="/map/vector_map"/>
      </node>
    </group>
  </group>
</launch>
