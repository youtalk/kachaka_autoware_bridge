<?xml version="1.0"?>
<launch>
  <arg name="vehicle_info_param_file"
       default="$(find-pkg-share kachaka_autoware_description)/config/vehicle_info.param.yaml"/>

  <!--
    Use the local fork of autoware_core_planning's launch (see
    _planning_core.launch.xml). The fork loads vehicle_info.param.yaml in
    mission_planner / path_generator / velocity_smoother (upstream forwards
    it only to behavior_velocity_planner / motion_velocity_planner) and
    sources motion_velocity_planner's launch_modules from a yaml so an empty
    list can be expressed (the upstream arg substitution into the param value
    attribute can't represent "[]").
  -->
  <include file="$(find-pkg-share kachaka_autoware_bridge)/launch/_planning_core.launch.xml">
    <arg name="vehicle_param_file" value="$(var vehicle_info_param_file)"/>
  </include>

  <!--
    Stock no-perception/no-EKF planning input fillers (acceleration via
    twist2accel + empty perception stubs). autoware_core planning blocks on
    these inputs otherwise, leaving /planning/trajectory empty.
  -->
  <include file="$(find-pkg-share kachaka_autoware_bridge)/launch/no_perception_stubs.launch.xml"/>
</launch>
