#!/usr/bin/env python3
# Copyright 2026 Yutaka Kondo
# Licensed under the Apache License, Version 2.0 (the "License").

"""Broadcast map->odom from the EKF's map->base_link estimate (AMCL-style).

ndt localization mode only. The EKF hardcodes a map->base_link TF broadcast,
but base_link already has parent base_footprint in the Kachaka tree, so that
edge can never go on /tf. Instead this adapter computes
map->odom = (map->base_link) * (odom->base_link)^-1 from the EKF
kinematic_state and the live wheel-odometry TF (odom->base_footprint passes
the tf_gate; base_footprint->base_link is static), and broadcasts THAT --
keeping the tree shape map->odom->base_footprint->base_link with exactly one
parent per frame.
"""

import sys

import rclpy
import rclpy.time
import tf2_ros
from geometry_msgs.msg import TransformStamped
from nav_msgs.msg import Odometry
from rclpy.duration import Duration
from rclpy.node import Node

from kachaka_autoware_bridge.se3 import map_to_odom


class MapToOdomAdapter(Node):
    def __init__(self) -> None:
        super().__init__("map_to_odom_adapter")
        self.declare_parameter("input_odom_topic", "/localization/kinematic_state")
        self.declare_parameter("map_frame", "map")
        self.declare_parameter("odom_frame", "odom")
        self.declare_parameter("base_frame", "base_link")
        self.map_frame = str(self.get_parameter("map_frame").value)
        self.odom_frame = str(self.get_parameter("odom_frame").value)
        self.base_frame = str(self.get_parameter("base_frame").value)

        self.tf_buffer = tf2_ros.Buffer()
        self.tf_listener = tf2_ros.TransformListener(self.tf_buffer, self)
        self.tf_broadcaster = tf2_ros.TransformBroadcaster(self)
        self.create_subscription(
            Odometry, str(self.get_parameter("input_odom_topic").value), self._on_odom, 10
        )
        self.get_logger().info("map_to_odom_adapter up")

    def _on_odom(self, msg: Odometry) -> None:
        try:
            # Latest odom->base rather than stamp-matched: wheel odometry runs
            # much faster than the EKF output, and the sub-tick mismatch is far
            # below the divergence thresholds that matter here.
            tr = self.tf_buffer.lookup_transform(
                self.odom_frame, self.base_frame, rclpy.time.Time(),
                timeout=Duration(seconds=0.1),
            )
        except tf2_ros.TransformException as exc:
            self.get_logger().warning(
                f"{self.odom_frame}->{self.base_frame} TF unavailable: {exc}",
                throttle_duration_sec=5.0,
            )
            return
        p, q = msg.pose.pose.position, msg.pose.pose.orientation
        ob_t = (tr.transform.translation.x, tr.transform.translation.y, tr.transform.translation.z)
        ob_q = (tr.transform.rotation.x, tr.transform.rotation.y,
                tr.transform.rotation.z, tr.transform.rotation.w)
        mo_t, mo_q = map_to_odom((p.x, p.y, p.z), (q.x, q.y, q.z, q.w), ob_t, ob_q)

        out = TransformStamped()
        out.header.stamp = msg.header.stamp
        out.header.frame_id = self.map_frame
        out.child_frame_id = self.odom_frame
        out.transform.translation.x, out.transform.translation.y, out.transform.translation.z = mo_t
        (out.transform.rotation.x, out.transform.rotation.y,
         out.transform.rotation.z, out.transform.rotation.w) = mo_q
        self.tf_broadcaster.sendTransform(out)


def main() -> int:
    rclpy.init()
    node = MapToOdomAdapter()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()
    return 0


if __name__ == "__main__":
    sys.exit(main())
