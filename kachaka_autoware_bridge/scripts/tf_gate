#!/usr/bin/env python3
# Copyright 2026 Yutaka Kondo
# Licensed under the Apache License, Version 2.0 (the "License").

"""Forward /kachaka/tf_raw to /tf, dropping the edges named in drop_edges.

See kachaka_autoware_bridge.tf_gate for the why. QoS mirrors tf2's dynamic
broadcaster (reliable / volatile / keep-last) with a deep subscriber queue so
a scheduling hiccup doesn't drop TF.
"""

import sys

import rclpy
from rclpy.node import Node
from rclpy.qos import QoSDurabilityPolicy, QoSHistoryPolicy, QoSProfile, QoSReliabilityPolicy
from tf2_msgs.msg import TFMessage

from kachaka_autoware_bridge.tf_gate import parse_edges, partition_transforms

TF_QOS = QoSProfile(
    reliability=QoSReliabilityPolicy.RELIABLE,
    durability=QoSDurabilityPolicy.VOLATILE,
    history=QoSHistoryPolicy.KEEP_LAST,
    depth=100,
)


class TfGateNode(Node):
    def __init__(self) -> None:
        super().__init__("tf_gate")
        self.declare_parameter("input_topic", "/kachaka/tf_raw")
        self.declare_parameter("drop_edges", "")
        self.drop = parse_edges(str(self.get_parameter("drop_edges").value))
        input_topic = str(self.get_parameter("input_topic").value)
        self.pub = self.create_publisher(TFMessage, "/tf", TF_QOS)
        self.create_subscription(TFMessage, input_topic, self._on_tf, TF_QOS)
        self.get_logger().info(
            f"tf_gate up: {input_topic} -> /tf, dropping {sorted(self.drop) or 'nothing'}"
        )

    def _on_tf(self, msg: TFMessage) -> None:
        kept, _ = partition_transforms(msg.transforms, self.drop)
        if kept:
            out = TFMessage()
            out.transforms = kept
            self.pub.publish(out)


def main() -> int:
    rclpy.init()
    node = TfGateNode()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()
    return 0


if __name__ == "__main__":
    sys.exit(main())
