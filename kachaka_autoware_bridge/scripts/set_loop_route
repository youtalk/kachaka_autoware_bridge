#!/usr/bin/env python3
# Copyright 2026 Yutaka Kondo
# Licensed under the Apache License, Version 2.0 (the "License").

"""Drive the robot onto the generated loop and set a (near) full-lap AD-API route.

Reads the loop centre/radius from loop_params.yaml (written by
kachaka_autoware_maps generate_loop_map) and the robot's current pose, then:

  1. Resolves the loop's TRAVEL DIRECTION from the live /map/vector_map (the
     lanelet at the robot's ring position). This must come from the loaded map,
     not a static guess: lanelet2's winding normalisation differs between a raw
     load and Autoware's map loader, so a hardcoded direction can be 180 deg
     wrong -- which makes autoware_route_handler reject the start lanelet (its
     direction must be within 90 deg of the ego heading) and fail with "Failed
     to find a proper route!". Falls back to loop_params.travel_direction.
  2. Preflight (drive_onto_ring, default true): drive the robot onto the nearest
     point of the loop centerline facing the travel direction, via Kachaka's own
     navigation (MOVE_TO_POSE). The robot is usually off the thin ring after
     "drive off-dock + generate map", so without this there is no start lanelet.
  3. Compute a goal just behind the robot in the travel direction (near-full lap)
     and call /api/routing/set_route_points.

Kachaka's MOVE_TO_POSE needs manual_control OFF (autonomous nav); Autoware then
drives via /kachaka/manual_control/cmd_vel which needs manual_control ON, so this
tool disables manual_control for the preflight and re-enables it afterwards. The
robot only drives the lap once operation mode is AUTONOMOUS (change_to_autonomous).
"""

import math
import os
import sys
import tempfile
from pathlib import Path

import rclpy
from autoware_adapi_v1_msgs.srv import ClearRoute, SetRoutePoints
from autoware_map_msgs.msg import LaneletMapBin
from kachaka_interfaces.action import ExecKachakaCommand
from kachaka_interfaces.msg import KachakaCommand
from nav_msgs.msg import Odometry
from rclpy.action import ActionClient
from rclpy.duration import Duration
from rclpy.node import Node
from rclpy.qos import QoSDurabilityPolicy, QoSHistoryPolicy, QoSProfile, QoSReliabilityPolicy
from std_srvs.srv import SetBool

from kachaka_autoware_bridge.loop_route import (
    compute_lap_goal,
    nearest_ring_pose,
    travel_direction_from_tangent,
)
from kachaka_autoware_bridge.trajectory_gen import yaw_to_quaternion
from kachaka_autoware_maps.loop_map_gen import parse_loop_params

DEFAULT_PARAMS = str(Path.home() / "maps" / "kachaka_loop" / "loop_params.yaml")
DEFAULT_ODOM_TOPIC = "/localization/kinematic_state"
DEFAULT_MAP_TOPIC = "/map/vector_map"
DEFAULT_SET_SERVICE = "/api/routing/set_route_points"
DEFAULT_CLEAR_SERVICE = "/api/routing/clear_route"
DEFAULT_COMMAND_ACTION = "/kachaka/kachaka_command/execute"
DEFAULT_MANUAL_CONTROL_SERVICE = "/kachaka/manual_control/set_enabled"
DEFAULT_ODOM_TIMEOUT_SEC = 30.0
DEFAULT_SERVICE_TIMEOUT_SEC = 10.0
DEFAULT_POSITION_TIMEOUT_SEC = 120.0
ALIGN_TOLERANCE_RAD = math.radians(60.0)  # route_handler gate is 90 deg; keep margin


def _yaw_from_quaternion(q) -> float:
    return math.atan2(2.0 * (q.w * q.z + q.x * q.y), 1.0 - 2.0 * (q.y * q.y + q.z * q.z))


def _angle_diff(a: float, b: float) -> float:
    return abs(math.atan2(math.sin(a - b), math.cos(a - b)))


class SetLoopRouteNode(Node):
    def __init__(self) -> None:
        super().__init__("set_loop_route")
        self.declare_parameter("loop_params_path", DEFAULT_PARAMS)
        self.declare_parameter("odom_topic", DEFAULT_ODOM_TOPIC)
        self.declare_parameter("behind_angle", 0.0)  # 0 => auto = 2*pi/num_segments
        self.declare_parameter("drive_onto_ring", True)
        self.declare_parameter("odom_timeout", DEFAULT_ODOM_TIMEOUT_SEC)
        self.declare_parameter("position_timeout", DEFAULT_POSITION_TIMEOUT_SEC)

        self.params_path = Path(str(self.get_parameter("loop_params_path").value)).expanduser()
        self.odom_topic = str(self.get_parameter("odom_topic").value)
        self.behind_angle = float(self.get_parameter("behind_angle").value)
        self.drive_onto_ring = bool(self.get_parameter("drive_onto_ring").value)
        self.odom_timeout_sec = float(self.get_parameter("odom_timeout").value)
        self.position_timeout_sec = float(self.get_parameter("position_timeout").value)

        self.loop = parse_loop_params(self.params_path.read_text())
        if self.behind_angle <= 0.0:
            self.behind_angle = 2.0 * math.pi / max(self.loop.num_segments, 3)

        latched = QoSProfile(
            reliability=QoSReliabilityPolicy.RELIABLE,
            durability=QoSDurabilityPolicy.TRANSIENT_LOCAL,
            history=QoSHistoryPolicy.KEEP_LAST, depth=1,
        )
        self.latest_odom: Odometry | None = None
        self.latest_map: LaneletMapBin | None = None
        self.create_subscription(Odometry, self.odom_topic, self._on_odom, 1)
        self.create_subscription(LaneletMapBin, DEFAULT_MAP_TOPIC, self._on_map, latched)
        self.set_cli = self.create_client(SetRoutePoints, DEFAULT_SET_SERVICE)
        self.clear_cli = self.create_client(ClearRoute, DEFAULT_CLEAR_SERVICE)
        self.manual_cli = self.create_client(SetBool, DEFAULT_MANUAL_CONTROL_SERVICE)
        self.move_client = ActionClient(self, ExecKachakaCommand, DEFAULT_COMMAND_ACTION)

    def _on_odom(self, msg: Odometry) -> None:
        self.latest_odom = msg

    def _on_map(self, msg: LaneletMapBin) -> None:
        self.latest_map = msg

    def _wait(self, attr: str, label: str, timeout_sec: float) -> bool:
        deadline = self.get_clock().now() + Duration(seconds=timeout_sec)
        while rclpy.ok() and getattr(self, attr) is None:
            if self.get_clock().now() > deadline:
                return False
            rclpy.spin_once(self, timeout_sec=0.1)
        return getattr(self, attr) is not None

    def wait_for_odom(self) -> bool:
        if not self._wait("latest_odom", self.odom_topic, self.odom_timeout_sec):
            self.get_logger().error(
                f"No {self.odom_topic} within {self.odom_timeout_sec}s; is "
                "localization up and the robot off the dock?"
            )
            return False
        return True

    def _pose(self) -> "tuple[float, float, float]":
        p = self.latest_odom.pose.pose
        return p.position.x, p.position.y, _yaw_from_quaternion(p.orientation)

    def _refresh_odom(self) -> None:
        for _ in range(10):
            rclpy.spin_once(self, timeout_sec=0.1)

    def _resolve_travel_direction(self, rx: float, ry: float) -> str:
        """Read the loop's travel direction from the live /map/vector_map.

        Falls back to loop_params.travel_direction if the map or lanelet2 python
        is unavailable, or the robot's ring point lies in no lanelet.
        """
        fallback = self.loop.travel_direction
        if not self._wait("latest_map", DEFAULT_MAP_TOPIC, 5.0):
            self.get_logger().warning(
                f"no {DEFAULT_MAP_TOPIC}; using loop_params direction '{fallback}'"
            )
            return fallback
        try:
            from lanelet2 import core, geometry, io
        except ImportError:
            self.get_logger().warning(f"lanelet2 python missing; using '{fallback}'")
            return fallback
        tmp = None
        try:
            with tempfile.NamedTemporaryFile("wb", suffix=".bin", delete=False) as handle:
                handle.write(bytes(self.latest_map.data))
                tmp = handle.name
            lmap = io.load(tmp, io.Origin(0.0, 0.0))
            theta = math.atan2(ry - self.loop.center_y, rx - self.loop.center_x)
            ring = core.BasicPoint2d(
                self.loop.center_x + self.loop.radius * math.cos(theta),
                self.loop.center_y + self.loop.radius * math.sin(theta),
            )
            here = [ll for ll in lmap.laneletLayer if geometry.inside(ll, ring)]
            if not here:
                self.get_logger().warning(f"ring point in no lanelet; using '{fallback}'")
                return fallback
            c = here[0].centerline
            tangent = math.atan2(c[-1].y - c[0].y, c[-1].x - c[0].x)
            direction = travel_direction_from_tangent(theta, tangent)
            self.get_logger().info(
                f"live map travel direction = {direction} (lanelet {here[0].id})"
            )
            return direction
        except Exception as exc:  # noqa: BLE001 - any failure -> fall back to hint
            self.get_logger().warning(f"could not read live map direction ({exc}); using '{fallback}'")
            return fallback
        finally:
            if tmp is not None and os.path.exists(tmp):
                os.unlink(tmp)

    def _set_manual_control(self, enabled: bool) -> None:
        """Best-effort toggle of Kachaka manual_control; logs and continues."""
        if not self.manual_cli.wait_for_service(timeout_sec=DEFAULT_SERVICE_TIMEOUT_SEC):
            self.get_logger().warning(
                f"{DEFAULT_MANUAL_CONTROL_SERVICE} unavailable; leaving manual_control as-is"
            )
            return
        fut = self.manual_cli.call_async(SetBool.Request(data=enabled))
        rclpy.spin_until_future_complete(self, fut, timeout_sec=DEFAULT_SERVICE_TIMEOUT_SEC)
        resp = fut.result()
        if resp is None or not resp.success:
            self.get_logger().warning(f"manual_control set_enabled({enabled}) did not confirm")

    def _drive_to_pose(self, x: float, y: float, yaw: float) -> bool:
        """Drive the robot to (x, y, yaw) via Kachaka MOVE_TO_POSE; blocks to done."""
        if not self.move_client.wait_for_server(timeout_sec=DEFAULT_SERVICE_TIMEOUT_SEC):
            self.get_logger().error(f"{DEFAULT_COMMAND_ACTION} unavailable; is the bridge up?")
            return False
        goal = ExecKachakaCommand.Goal()
        goal.kachaka_command.command_type = KachakaCommand.MOVE_TO_POSE_COMMAND
        goal.kachaka_command.move_to_pose_command_x = x
        goal.kachaka_command.move_to_pose_command_y = y
        goal.kachaka_command.move_to_pose_command_yaw = yaw
        self.get_logger().info(f"Driving onto loop: target=({x:.3f}, {y:.3f}, yaw={yaw:.3f})")
        send_fut = self.move_client.send_goal_async(goal)
        rclpy.spin_until_future_complete(self, send_fut, timeout_sec=DEFAULT_SERVICE_TIMEOUT_SEC)
        handle = send_fut.result()
        if handle is None or not handle.accepted:
            self.get_logger().error("MOVE_TO_POSE goal was rejected")
            return False
        result_fut = handle.get_result_async()
        rclpy.spin_until_future_complete(self, result_fut, timeout_sec=self.position_timeout_sec)
        wrapped = result_fut.result()
        if wrapped is None:
            self.get_logger().error(f"MOVE_TO_POSE did not finish within {self.position_timeout_sec}s")
            return False
        result = wrapped.result
        if not result.success:
            self.get_logger().error(
                f"MOVE_TO_POSE failed: error_code={result.error_code} {result.message}"
            )
            return False
        return True

    def _ensure_on_ring(self, travel_direction: str) -> bool:
        """Drive the robot onto the nearest ring point facing travel, if needed."""
        rx, ry, ryaw = self._pose()
        target = nearest_ring_pose(
            self.loop.center_x, self.loop.center_y, self.loop.radius, rx, ry, travel_direction
        )
        dist_err = abs(math.hypot(rx - self.loop.center_x, ry - self.loop.center_y) - self.loop.radius)
        yaw_err = _angle_diff(ryaw, target.yaw)
        if dist_err <= self.loop.lane_width * 0.4 and yaw_err <= ALIGN_TOLERANCE_RAD:
            self.get_logger().info(
                f"Already on the loop (radial err {dist_err:.3f} m, yaw err "
                f"{math.degrees(yaw_err):.0f} deg); skipping drive-on."
            )
            return True
        self._set_manual_control(False)  # Kachaka autonomous nav owns the move
        if not self._drive_to_pose(target.x, target.y, target.yaw):
            return False
        self._refresh_odom()
        return True

    def call(self) -> bool:
        rx, ry, _ = self._pose()
        travel_direction = self._resolve_travel_direction(rx, ry)
        if self.drive_onto_ring and not self._ensure_on_ring(travel_direction):
            return False
        # Re-enable manual_control so Autoware cmd_vel reaches the robot on
        # change_to_autonomous (STOP mode still gates motion until then).
        self._set_manual_control(True)

        rx, ry, _ = self._pose()
        goal = compute_lap_goal(
            self.loop.center_x, self.loop.center_y, self.loop.radius, rx, ry,
            behind_angle_rad=self.behind_angle, travel_direction=travel_direction,
        )

        if self.clear_cli.wait_for_service(timeout_sec=DEFAULT_SERVICE_TIMEOUT_SEC):
            fut = self.clear_cli.call_async(ClearRoute.Request())
            rclpy.spin_until_future_complete(self, fut, timeout_sec=DEFAULT_SERVICE_TIMEOUT_SEC)
            if fut.result() is None:
                self.get_logger().warning("clear_route did not confirm; continuing")
        else:
            self.get_logger().warning(f"{DEFAULT_CLEAR_SERVICE} unavailable; skipping clear")

        if not self.set_cli.wait_for_service(timeout_sec=DEFAULT_SERVICE_TIMEOUT_SEC):
            self.get_logger().error(f"{self.set_cli.srv_name} unavailable; is AD-API up?")
            return False
        req = SetRoutePoints.Request()
        req.header.frame_id = "map"
        req.header.stamp = self.get_clock().now().to_msg()
        req.option.allow_goal_modification = True
        req.goal.position.x = goal.x
        req.goal.position.y = goal.y
        qz, qw = yaw_to_quaternion(goal.yaw)
        req.goal.orientation.z = qz
        req.goal.orientation.w = qw
        fut = self.set_cli.call_async(req)
        rclpy.spin_until_future_complete(self, fut, timeout_sec=DEFAULT_SERVICE_TIMEOUT_SEC)
        resp = fut.result()
        if resp is None:
            self.get_logger().error("set_route_points call timed out")
            return False
        if not resp.status.success:
            self.get_logger().error(
                f"set_route_points rejected: code={resp.status.code} {resp.status.message}"
            )
            return False
        self.get_logger().info(
            f"Route set: goal=({goal.x:.3f}, {goal.y:.3f}) yaw={goal.yaw:.3f} "
            f"({travel_direction}). Call change_to_autonomous to drive the lap."
        )
        return True


def main() -> int:
    rclpy.init()
    node = None
    try:
        node = SetLoopRouteNode()
        if not node.wait_for_odom():
            return 1
        return 0 if node.call() else 1
    except (FileNotFoundError, KeyError, TypeError, ValueError) as exc:
        msg = f"set_loop_route: {exc}"
        if node is not None:
            node.get_logger().error(msg)
        else:
            print(msg, file=sys.stderr)
        return 1
    finally:
        if node is not None:
            node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()


if __name__ == "__main__":
    sys.exit(main())
